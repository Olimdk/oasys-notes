{
  "name": "project",
  "description": "A project with status, due date and linked notes.",
  "fields": {
    "title": { "type": "string", "required": true },
    "status": { "type": "enum", "values": ["idea", "active", "blocked", "done"], "default": "idea" },
    "due":    { "type": "date" },
    "tags":   { "type": "list" },
    "links":  { "type": "list" }
  }
}
